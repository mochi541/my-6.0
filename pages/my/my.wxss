.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e8edf2 100%);
  padding: 20rpx;
  padding-top: 0;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  width: 100%;
}

.user-card {
  background: linear-gradient(135deg, #409EFF 0%, #66b1ff 100%);
  color: #ffffff;
  width: 100%;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.user-text {
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tip {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.set-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
}

.set-row:last-child {
  border-bottom: none;
}

.set-row slider {
  width: 200rpx;
  margin-left: 20rpx;
}

.slider-value {
  color: #409EFF;
  font-size: 28rpx;
  margin-left: 10rpx;
  min-width: 60rpx;
  text-align: right;
}

.picker-text {
  color: #409EFF;
  font-size: 28rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  max-width: 90%;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.pwd-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  text-align: center;
  letter-spacing: 8rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 10rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: #409EFF;
  color: #ffffff;
}