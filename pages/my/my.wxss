/* pages/my/my.wxss */
/* 引入全局样式（可选，确保样式统一） */
@import "../../app.wxss";

.page-container {
  padding-bottom: 20rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
}
.user-text {
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.nickname {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

/* 设置项补充 */
.setting-card .set-row {
  border-bottom: 1rpx solid #F5F7FA;
}
.setting-card .set-row:last-child {
  border-bottom: none;
}
.picker-text {
  font-size: 28rpx;
  color: #606266;
}

/* 适配滑块样式 */
slider {
  width: 400rpx;
}

/* 自定义密码弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #909399;
  text-align: center;
  margin-bottom: 30rpx;
}

.pwd-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #DCDFE6;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  text-align: center;
  letter-spacing: 10rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.pwd-input:focus {
  border-color: #409EFF;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.btn-cancel {
  background: #F5F7FA;
  color: #606266;
}

.btn-confirm {
  background: #409EFF;
  color: #fff;
}

/* 让所有文本元素继承父级字体大小 */
.set-row text,
.title,
.nickname,
.tip,
.desc,
.picker-text,
.modal-title,
.modal-desc,
.pwd-input,
.btn-cancel,
.btn-confirm {
  font-size: inherit;
}