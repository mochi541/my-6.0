<!-- pages/my/my.wxml -->
<view class="page-container" style="font-size: {{Math.round(fontSize * 28)}}rpx;">
  <!-- 1. 用户信息卡片 -->
  <view class="card user-card">
    <view class="user-info" bindtap="getUserProfile">
      <image class="avatar" src="{{userInfo.avatarUrl || '/image/damie.png'}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="nickname">{{userInfo.nickName || '点击登录/授权'}}</text>
        <text class="tip">青少年近视防控助手</text>
      </view>
    </view>
  </view>

  <!-- 2. 核心设置模块 -->
  <view class="card setting-card">
    <text class="title">系统设置</text>
    
    <!-- 2.1 提醒开关 -->
    <view class="set-row">
      <text>姿势提醒</text>
      <switch checked="{{postureRemind}}" bindchange="switchPostureRemind"></switch>
    </view>
    <view class="set-row">
      <text>护眼提醒</text>
      <switch checked="{{eyeRemind}}" bindchange="switchEyeRemind"></switch>
    </view>
    <view class="set-row">
      <text>震动提醒</text>
      <switch checked="{{vibrate}}" bindchange="switchVibrate"></switch>
    </view>

    <!-- 2.2 字体大小调节 -->
    <view class="set-row">
      <text>字体大小</text>
      <view style="display: flex; align-items: center; flex: 1; justify-content: flex-end;">
        <slider 
          value="{{fontSize}}" 
          min="0.8" 
          max="1.2" 
          step="0.1" 
          bindchange="changeFontSize"
          activeColor="#409EFF"
          backgroundColor="#e0e0e0"
          block-size="20"
        />
        <text class="slider-value">{{fontSize.toFixed(1)}}</text>
      </view>
    </view>

    <!-- 2.3 最长学习时长限制 -->
    <view class="set-row">
      <text>单次最长学习时长(分钟)</text>
      <picker mode="selector" range="{{durationOptions}}" range-key="name" value="{{durationIndex}}" bindchange="changeMaxDuration">
        <view class="picker-text">{{durationOptions[durationIndex].name}}</view>
      </picker>
    </view>

    <!-- 2.4 青少年模式 -->
    <view class="set-row">
      <text>青少年模式</text>
      <switch checked="{{teenMode}}" bindchange="switchTeenMode"></switch>
    </view>
  </view>

  <!-- 3. 家长监督模块 -->
  <view class="card">
    <text class="title">家长监督</text>
    <view class="set-row" bindtap="setParentPwd">
      <text>设置查看密码</text>
      <icon type="arrowright" color="#909399"></icon>
    </view>
    <view class="set-row" bindtap="bindParentWechat">
      <text>绑定家长微信</text>
      <icon type="arrowright" color="#909399"></icon>
    </view>
    <view class="set-row" bindtap="parentViewStats">
      <text>家长查看数据</text>
      <icon type="arrowright" color="#909399"></icon>
    </view>
  </view>

  <!-- 4. 辅助功能模块 -->
  <view class="card">
    <view class="set-row" bindtap="showAbout">
      <text>关于我们</text>
      <icon type="arrowright" color="#909399"></icon>
    </view>
    <view class="set-row" bindtap="showUsage">
      <text>使用说明</text>
      <icon type="arrowright" color="#909399"></icon>
    </view>
    <view class="set-row" bindtap="feedback">
      <text>意见反馈</text>
      <icon type="arrowright" color="#909399"></icon>
    </view>
  </view>

  <!-- 自定义密码设置弹窗 -->
  <view class="modal-mask" wx:if="{{showPwdModal}}" bindtap="closePwdModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">{{pwdModalTitle}}</view>
      <view class="modal-desc">请输入4位数字密码（仅家长查看数据使用）</view>
      <input 
        class="pwd-input" 
        type="number" 
        maxlength="4" 
        placeholder="请输入4位数字" 
        value="{{newPwd}}"
        bindinput="onPwdInput"
        focus="{{showPwdModal}}"
      />
      <view class="modal-buttons">
        <button class="btn-cancel" bindtap="closePwdModal">取消</button>
        <button class="btn-confirm" bindtap="confirmSetPwd">确定</button>
      </view>
    </view>
  </view>

  <!-- 自定义密码验证弹窗 -->
  <view class="modal-mask" wx:if="{{showVerifyModal}}" bindtap="closeVerifyModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">家长验证</view>
      <view class="modal-desc">请输入4位查看密码</view>
      <input 
        class="pwd-input" 
        type="number" 
        password="{{true}}"
        maxlength="4" 
        placeholder="请输入密码" 
        value="{{verifyPwd}}"
        bindinput="onVerifyPwdInput"
        focus="{{showVerifyModal}}"
      />
      <view class="modal-buttons">
        <button class="btn-cancel" bindtap="closeVerifyModal">取消</button>
        <button class="btn-confirm" bindtap="confirmVerifyPwd">确定</button>
      </view>
    </view>
  </view>
</view>