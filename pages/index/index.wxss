.container {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}
.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 20rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.camera {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  width: 180rpx;
  height: 240rpx;
  border-radius: 12rpx;
  opacity: 0.8;
  z-index: 10;
}

/* 坐姿提示样式 - 摄像头下方 */
.pose-tip {
  position: fixed;
  top: 270rpx;
  right: 20rpx;
  width: 180rpx;
  background: rgba(245, 108, 108, 0.9);
  color: #fff;
  padding: 10rpx 15rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
  z-index: 11;
  text-align: center;
  line-height: 1.4;
  animation: fadeInOut 3s ease-in-out;
}

@keyframes fadeInOut {
  0% { opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { opacity: 0; }
}

.time-box {
  text-align: center;
  margin-top: 0rpx;
}
.time-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #409EFF;
  margin-bottom: 0rpx;
}
.btn-group {
  margin: 0rpx 0;
}
.btn {
  border-radius: 50rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
}
.btn-primary {
  background: #409EFF;
  color: white;
}
.btn-warn {
  background: #F56C6C;
  color: white;
}
.btn-disabled {
  background: #909399;
  color: white;
}
.btn-hover {
  opacity: 0.8;
}
.card {
  background: rgba(245, 245, 245, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0rpx 0;
  text-align: center;
}
.desc {
  font-size: 28rpx;
  color: #666;
}