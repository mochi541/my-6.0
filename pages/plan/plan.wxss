page{
  background: #f5f9ff;
  font-family: system-ui;
}
.container{
  padding: 20rpx;
}
.card{
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,80,255,0.06);
}
.card-title{
  font-size: 36rpx;
  font-weight: bold;
  color: #1d72ff;
  margin-bottom: 24rpx;
}

/* 20-20-20 规则 */
.rule-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/*让三个卡片水平并排 */
.rule-row {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-top: 16rpx;
}

.rule-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
}

.num {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e6f0ff;
  color: #1d72ff;
  font-size: 48rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.text {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  line-height: 1.4;
}

.tip {
  width: 100%;
  text-align: center;
  margin-top: 24rpx;
  color: #666;
  font-size: 26rpx;
}

/* 播放器 */
/* 进度条容器（需定位，让滑块能绝对定位） */
.progress {
  position: relative;
  width: 100%;
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  margin: 15rpx 0;
}
/* 已播放进度条 */
.progress-bar {
  height: 100%;
  background: #007aff;
  border-radius: 4rpx;
}
/* 拖动滑块（新增） */
.progress-dot {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background: #007aff;
  border-radius: 50%;
}
/* 保持原有按钮/时间样式不变 */
.play-btn {
  background: #007aff;
  color: #fff;
  border-radius: 4rpx;
  padding: 8rpx 20rpx;
}
.time {
  font-size: 24rpx;
  color: #666;
}

/* 用眼建议 */
.item{
  margin-bottom: 28rpx;
}
.item-title{
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}
.item-desc{
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 6rpx;
}
/* 眼保健操音频样式 */
.eye-audio-wrap {
  margin: 20rpx;
  padding: 30rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  text-align: center;
}
.eye-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
}
.eye-play-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
}